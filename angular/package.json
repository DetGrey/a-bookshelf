{
  "name": "a-bookshelf",
  "version": "0.0.0",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "volta": {
    "node": "22.12.0",
    "npm": "10.9.2"
  },
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-dev-env.js",
    "start": "ng serve",
    "prebuild": "node scripts/generate-prod-env.js",
    "build": "ng build && cp dist/a-bookshelf/browser/index.html dist/a-bookshelf/browser/404.html",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint \"src/**/*.{ts,html}\" && node scripts/lint-internal-links.js",
    "lint:fix": "eslint \"src/**/*.{ts,html}\" --fix",
    "test": "jest --passWithNoTests --runInBand"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@angular/service-worker": "^21.2.9",
    "@supabase/supabase-js": "^2.103.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/animations": "^21.2.8",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  }
}
